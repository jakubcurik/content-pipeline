{
  "mcpServers": {
    "dataforseo": {
      "command": "npx",
      "args": ["-y", "dataforseo-mcp-server"],
      "env": {
        "DATAFORSEO_USERNAME": "${user_config.dataforseo_username}",
        "DATAFORSEO_PASSWORD": "${user_config.dataforseo_password}"
      }
    },
    "google-gsc": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/dist/google-gsc.js"],
      "env": {
        "GOOGLE_CLIENT_ID": "${user_config.google_client_id}",
        "GOOGLE_CLIENT_SECRET": "${user_config.google_client_secret}",
        "GOOGLE_REFRESH_TOKEN": "${user_config.google_refresh_token}"
      }
    },
    "google-ga4": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/dist/google-ga4.js"],
      "env": {
        "GOOGLE_CLIENT_ID": "${user_config.google_client_id}",
        "GOOGLE_CLIENT_SECRET": "${user_config.google_client_secret}",
        "GOOGLE_REFRESH_TOKEN": "${user_config.google_refresh_token}"
      }
    }
  }
}
