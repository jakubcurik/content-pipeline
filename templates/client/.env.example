# Per-klient připojení k webu. Zkopíruj na .env a vyplň.
# POZOR: .env je v .gitignore — NIKDY ho necommituj.
#
# Agenturní API klíče (DataForSEO, Google OAuth, Gemini) sem NEPATŘÍ —
# ty se nastavují jednou v /plugin → content-pipeline → Configure options.
# Tady jsou jen věci specifické pro tenhle web.

# --- WordPress REST API (jen když publish.target = "wordpress") ---
WP_URL=https://example.com
WP_USER=
# App Password z WP (Uživatelé → Profil → Application Passwords).
# POZOR: mezery v hesle ZACHOVEJ, nestripuj je.
WP_APP_PASSWORD=

# --- WordPress přes SSH + WP-CLI (volitelné, pro pokročilé operace) ---
# Nech prázdné, pokud používáš jen REST API.
SSH_HOST=
SSH_USER=
WP_PATH=~/domains/example.com/www
